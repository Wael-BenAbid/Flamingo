<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".FlamingoApplication"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/flamingo"
        android:roundIcon="@mipmap/flamingo_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FlamingoAndroid">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".presentation.activities.AdminLoginActivity"
            android:exported="false" />

        <activity
            android:name=".presentation.activities.HomeActivity"
            android:exported="false" />

        <activity
            android:name=".presentation.activities.TableOrderingActivity"
            android:exported="false" />

        <activity
            android:name=".presentation.activities.KitchenDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".presentation.activities.PaymentActivity"
            android:exported="false" />

    </application>

</manifest>
