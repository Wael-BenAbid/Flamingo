<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:background="@drawable/bg_login_gradient"
    android:orientation="vertical"
    android:gravity="bottom"
    android:padding="24dp">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@mipmap/flamingo"
        android:contentDescription="@string/flamingo_label" />

    <TextView
        android:id="@+id/tvDrawerUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/admin_flamingo"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDrawerUserEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/admin_email_placeholder"
        android:textColor="#DCECF4"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvDrawerUserRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_chip_rounded"
        android:paddingHorizontal="14dp"
        android:paddingVertical="7dp"
        android:text="Responsable"
        android:textColor="@color/ocean_dark"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>
