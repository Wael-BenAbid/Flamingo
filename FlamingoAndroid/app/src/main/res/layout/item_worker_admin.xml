<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="22dp"
    app:cardElevation="5dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Gradient header ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_workers_hero"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="18dp"
            android:paddingVertical="16dp">

            <!-- Avatar circle -->
            <TextView
                android:id="@+id/tvWorkerAvatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:background="@drawable/bg_worker_avatar"
                android:text="W"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Name + Category -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWorkerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nom complet"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvWorkerCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_stats_chip_white"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="Serveur"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Presence chip -->
            <TextView
                android:id="@+id/tvWorkerPresence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_rounded"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="absent"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true" />
        </LinearLayout>

        <!-- ── White body ───────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Stats text (2 lines) -->
            <TextView
                android:id="@+id/tvWorkerStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="40 DT/jour • 15 jours présents"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:lineSpacingExtra="4dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="@color/divider" />

            <!-- Action buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWorkerAdvance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Avance"
                    android:textAllCaps="false"
                    android:textSize="11sp"
                    android:textColor="@color/secondary"
                    app:backgroundTint="@color/secondaryContainer"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWorkerPenalty"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Pénalité"
                    android:textAllCaps="false"
                    android:textSize="11sp"
                    android:textColor="@color/onTertiaryContainer"
                    app:backgroundTint="@color/tertiaryContainer"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWorkerPayment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Paiement"
                    android:textAllCaps="false"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/success"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- Delete button (outlined) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWorkerDelete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Supprimer"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="@color/error"
                app:backgroundTint="@color/errorContainer"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
