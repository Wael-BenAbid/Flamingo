<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="22dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvWorkerAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:background="@drawable/bg_logo_ocean"
                android:text="W"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/tvWorkerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nom complet"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvWorkerCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Serveur"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvWorkerPresence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_rounded"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="absent"
                android:textColor="@color/text_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvWorkerStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="40 DT/jour • 15 jours • 0 avances • 0 pénalités"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWorkerAdvance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+ Avance"
                android:textAllCaps="false"
                android:textSize="12sp"
                app:backgroundTint="@color/ocean_light"
                app:cornerRadius="14dp"
                android:textColor="@color/ocean_dark" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWorkerPenalty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="+ Pénalité"
                android:textAllCaps="false"
                android:textSize="12sp"
                app:backgroundTint="@color/warning"
                app:cornerRadius="14dp"
                android:textColor="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWorkerPayment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Paiement"
                android:textAllCaps="false"
                android:textSize="12sp"
                app:backgroundTint="@color/success"
                app:cornerRadius="14dp"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWorkerDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Supprimer"
            android:textAllCaps="false"
            android:textSize="12sp"
            app:backgroundTint="@color/error"
            app:cornerRadius="14dp"
            android:textColor="@android:color/white" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
